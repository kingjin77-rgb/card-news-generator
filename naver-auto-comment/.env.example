# 네이버 계정 정보
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password

# Anthropic Claude API 키
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# 댓글 간격 설정 (분 단위)
COMMENT_INTERVAL_MIN=30
COMMENT_INTERVAL_MAX=90

# 하루 최대 댓글 수
DAILY_LIMIT=20

# 자동 실행 스케줄 (cron 형식: 오전9시, 오후2시, 오후7시)
SCHEDULE_CRON=0 9,14,19 * * *

# 브라우저 숨김 여부 (true = 백그라운드, false = 화면에 표시)
HEADLESS=true

# Claude 모델 선택
CLAUDE_MODEL=claude-haiku-4-5-20251001
